          <mxGeometry x="320" y="150" width="160" height="200" as="geometry" />
        </mxCell>
        <!-- ESP32-CAM Pins -->
        <mxCell id="esp_5v" value="5V" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="esp32_cam">
          <mxGeometry x="10" y="40" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="esp_gnd" value="GND" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="esp32_cam">
