        <mxCell id="esp_gpio13" value="GPIO 13" style="text;html=1;align=right;verticalAlign=middle;fontSize=11;" vertex="1" parent="esp32_cam">
          <mxGeometry x="90" y="140" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- PIR Sensor -->
        <mxCell id="pir_sensor" value="&lt;b&gt;HC-SR501&lt;/b&gt;&lt;br&gt;(PIR Sensor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;paddingTop=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="140" height="150" as="geometry" />
        </mxCell>
        <!-- PIR Pins -->
        <mxCell id="pir_vcc" value="VCC" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="pir_sensor">
          <mxGeometry x="10" y="40" width="40" height="20" as="geometry" />
