        <!-- Signal Wire GPIO 13 to PIR OUT (Blue) -->
        <mxCell id="wire_sig" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#0000FF;" edge="1" parent="1" source="esp_gpio13" target="pir_out">
          <mxGeometry relative="1" as="geometry">
