        <mxCell id="cooldown" value="Đặt hẹn giờ RTC (1 tiếng)&lt;br&gt;Và quay lại Deep Sleep" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
