  <diagram id="esp32-fsm" name="Lưu đồ thuật toán ESP32">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Hình 3.4: Lưu đồ thuật toán (Flowchart) vòng lặp chính của ESP32-CAM&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="550" height="30" as="geometry" />
        </mxCell>

        <!-- Nodes -->
        <mxCell id="start" value="CẤP NGUỒN / KHỞI ĐỘNG" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="60" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="init" value="Khởi tạo Camera &amp;amp;&lt;br&gt;Kết nối Wi-Fi" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="start_server" value="Deep Sleep&lt;br&gt;(Chờ PIR hoặc RTC Timer)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="350" y="230" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="idle_loop" value="Kiểm tra lý do&lt;br&gt;Wake-up (esp_sleep_get_wakeup_cause)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="340" y="320" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="check_http" value="Nguồn thức giấc&lt;br&gt;là RTC Timer?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="120" y="410" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="serve_http" value="Bỏ qua Delay 2s&lt;br&gt;Vào thẳng hàm chụp ảnh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="130" y="520" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="check_pir" value="Nguồn thức giấc&lt;br&gt;là Cảm biến PIR?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="540" y="410" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="delay_2s" value="Bật cờ Motion, Delay 2s&lt;br&gt;(Chờ người cất/lấy đồ)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="550" y="520" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="flash_on" value="Bật Flash LED&lt;br&gt;Xả 2 frame ảnh cũ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="550" y="600" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="capture" value="Chụp ảnh Snapshot&lt;br&gt;(Bật đèn Flash)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="550" y="680" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="encode" value="Tắt Flash LED&lt;br&gt;Mã hóa Base64" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="550" y="760" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="http_post" value="HTTP POST Payload&lt;br&gt;tới Backend API" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
